{
  "name": "test-end-to-end",
  "version": "2.0.0",
  "description": "Autonomous E2E QA engine for Claude Code — 13 specialized agents, MCP server, Zero-Token Bypass",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "e2e:init": "node dist/index.js init",
    "e2e:audit": "node dist/index.js audit",
    "e2e:shadow": "node dist/index.js shadow",
    "e2e:diff": "node dist/index.js diff",
    "e2e:repair": "node dist/index.js repair",
    "e2e:coverage": "node dist/index.js coverage",
    "e2e:update": "node dist/index.js update",
    "e2e:update:dry": "node dist/index.js update --dry-run",
    "e2e:sentinel": "node dist/index.js sentinel",
    "e2e:arch": "node dist/index.js arch",
    "e2e:chaos": "node dist/index.js chaos",
    "setup": "bash scripts/setup.sh",
    "security-fix": "node dist/agents/dependabot.js",
    "dashboard": "node dist/server/start.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "express": "^4.19.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.19.43",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.0",
    "cypress": "^13.9.0",
    "ts-morph": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.3"
  }
}
