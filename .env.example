# test-end-to-end — Template de configuration
# Copiez ce fichier en .env et remplissez les variables souhaitées.
# Toutes les intégrations sont OPT-IN : une variable absente désactive le module.

# ── LLM local (Zero-Token Bypass) ─────────────────────────────────────────────
# Installez Ollama : https://ollama.ai
# Lancez : ollama pull llama3.2
OLLAMA_HOST=http://127.0.0.1:11434

# ── Dashboard ─────────────────────────────────────────────────────────────────
E2E_PORT=4321

# ── GitHub (Ghostwriter + Sentinel) ───────────────────────────────────────────
# Créez un token sur : https://github.com/settings/tokens
# Permissions requises : repo, pull_requests, workflows
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# ── ChatOps — Slack ───────────────────────────────────────────────────────────
# Créez un webhook sur : https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── ChatOps — Discord ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── ChatOps — Microsoft Teams ─────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Atlassian — Jira + Xray ───────────────────────────────────────────────────
# Token API : https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://monprojet.atlassian.net
JIRA_TOKEN=ATATT3xxxxxxxxxxxxxxxxxxx
JIRA_USER_EMAIL=dev@monprojet.com
JIRA_PROJECT_KEY=QA

# ── Trello ────────────────────────────────────────────────────────────────────
# Clé API : https://trello.com/app-key
# Token : https://trello.com/1/authorize?expiration=never&scope=read,write&key=VOTRE_CLE
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_TODO_LIST_ID=
TRELLO_DONE_LIST_ID=

# ── Stripe (simulation webhooks — test env uniquement) ────────────────────────
# Secret webhook depuis : https://dashboard.stripe.com/webhooks (mode test)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── OVHcloud ──────────────────────────────────────────────────────────────────
# Créez vos credentials : https://api.ovh.com/createToken/index.cgi
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_PROJECT_ID=
OVH_SERVICE_NAME=

# ── IONOS (déploiement via GitHub Actions workflow_dispatch) ──────────────────
IONOS_GITHUB_REPO=owner/repo
IONOS_GITHUB_TOKEN=
IONOS_WORKFLOW_FILE=deploy.yml
IONOS_DEPLOY_BRANCH=main

# ── Hostinger (webhook de déploiement) ───────────────────────────────────────
HOSTINGER_DEPLOY_WEBHOOK_URL=

# ── Récupération logs SSH post-crash ──────────────────────────────────────────
SSH_HOST=
SSH_PORT=22
SSH_USER=ubuntu
SSH_PRIVATE_KEY=/home/user/.ssh/id_rsa

# ── Sécurité dépendances ──────────────────────────────────────────────────────
# Sévérité minimale pour déclencher un correctif : critical|high|moderate|low
DEPENDABOT_MIN_SEVERITY=high
